# Environment variables - NEVER commit the actual .env file!
MONGODB_URL=your_mongodb_connection_string_here
GROQ_API_KEY=your_groq_api_key_here

# WhatsApp Provider (waapi)
WHATSAPP_PROVIDER=waapi

# WaAPI Configuration
# Get your token from: https://panel.waapi.app/
# Instance URL format: https://waapi.app/api/v1/instances/YOUR_INSTANCE_ID
WAAPI_TOKEN=your_waapi_token_here
WAAPI_INSTANCE_URL=https://waapi.app/api/v1/instances/YOUR_INSTANCE_ID

BACKEND_PORT=8001
UPLOAD_DIR=./uploads

# Alert Recipients (comma-separated phone numbers without + sign)
# Format: 923001234567 (country code + number, no spaces)
# Example: 923001234567,923009876543
ALERT_PHONE_NUMBERS=923001234567

# Cloudinary Configuration (recommended for WhatsApp images)
# Sign up at: https://cloudinary.com/users/register_free
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
